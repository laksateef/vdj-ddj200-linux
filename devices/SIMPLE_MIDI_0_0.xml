    <button note="0x54" name="PFL" deck="1" channel="0" toggle="true" />
    <button note="0x58" name="SYNC" deck="1" channel="0" toggle="true" />
    <button note="0x3F" name="SHIFT" deck="1" channel="0" />
    <button note="0x36" name="WHEEL_TOUCH" deck="1" channel="0" />

    <led note="0x0B" name="LED_PLAY" default="PLAY" deck="1" channel="0" />
    <led note="0x0C" name="LED_CUE" default="CUE" deck="1" channel="0" />
    <led note="0x58" name="LED_SYNC" default="SYNC" deck="1" channel="0" />

