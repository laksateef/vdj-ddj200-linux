    <!-- DECK 2 (channel 1) -->
    <button note="0x0B" name="PLAY" deck="2" channel="1" toggle="true" />
    <button note="0x0C" name="CUE" deck="2" channel="1" />
    <button note="0x54" name="PFL" deck="2" channel="1" toggle="true" />
    <button note="0x58" name="SYNC" deck="2" channel="1" toggle="true" />
