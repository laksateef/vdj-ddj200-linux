    <button note="0x01" name="PAD2" deck="1" channel="7" toggle="true" />
    <button note="0x02" name="PAD3" deck="1" channel="7" toggle="true" />
    <button note="0x03" name="PAD4" deck="1" channel="7" toggle="true" />
    <button note="0x04" name="PAD5" deck="1" channel="7" toggle="true" />
