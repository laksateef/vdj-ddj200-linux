<?xml version="1.0" encoding="UTF-8"?>
<device name="SIMPLE_MIDI_0_0" author="Feff" type="MIDI" decks="2"
        drivername="DDJ-200 - DDJ-200 MIDI 1"
        drivernameout="DDJ-200 - DDJ-200 MIDI 1"
